{
  "discord": {
    "token": "PUT_DISCORD_BOT_TOKEN_IN_ENV",
    "guild_id": "",
    "prefix": "!"
  },

  "youtube": {
    "api_key": "YOUR_YOUTUBE_API_KEY_HERE"
  },

  "database": {
    "driver": "sqlite",
    "sqlite": {
      "path": "data/bot.db"
    },
    "mongodb": {
      "uri": "mongodb://localhost:27017",
      "database": "discord_bot"
    }
  },

  "minecraft": {
    "enabled": false,
    "rcon_ip": "localhost",
    "rcon_port": 25575,
    "rcon_password": "your_rcon_password",
    "link_backend": "file"
  },

  "permissions": {
    "admin_roles": ["Admin", "Owner"],
    "moderator_roles": ["Moderator", "Mod"],
    "dj_roles": ["DJ", "Music"]
  },

  "music": {
    "enabled": true,
    "backend": "lavalink",
    "max_queue_size": 100,
    "max_song_duration": 600,
    "allow_playlists": true,
    "default_volume": 50,
    "direct": {
      "ytdlp_path": "./yt-dlp",
      "ffmpeg_path": "ffmpeg"
    },
    "lavalink": {
      "host": "ip",
      "port": 25615,
      "password": "youshallnotpass",
      "secure": false
    }
  },

  "welcome": {
    "enabled": true,
    "channel_id": "PUT_WELCOME_CHANNEL_ID_HERE",
    "embed": {
      "colour": "#f74343",
      "title": "Welcome to Oreo Studios !",
      "message": ":smile: Welcome to you %joined_user%, on Oreo Studios !",
      "thumbnail": "BOT",
      "image_enabled": true,
      "image_url": "https://media.discordapp.net/attachments/1321509685031075914/1458092765333295238/oreostudios.png?ex=695e6235&is=695d10b5&hm=b7fbbbbdf5aa29977947913235d8094d17429f8f81067429bfd7c56e870b18fa&=&format=webp&quality=lossless"
    }
  },

  "leave": {
    "enabled": true,
    "channel_id": "PUT_LEAVE_CHANNEL_ID_HERE",
    "embed": {
      "colour": "#f74343",
      "title": "Goodbye!",
      "message": ":slight_frown: %joined_user% has recently dropped out!",
      "thumbnail": "BOT",
      "image_enabled": false,
      "image_url": "https://animagelink.png/"
    }
  },

  "moderation": {
    "mod_log_channel": "",
    "mute_role": "",
    "auto_mod": {
      "enabled": true,
      "max_mentions": 5,
      "max_lines": 30,
      "anti_spam_seconds": 5,
      "anti_spam_count": 5
    }
  },

  "chat_bridge": {
    "enabled": false,
    "rabbitmq_uri": "",
    "mc_channel_id": "",
    "ban_sync": false,
    "mod_sync": false
  },

  "custom_commands": [
    {
      "name": "example",
      "description": "An example custom command",
      "message": "This is the response to /example!",
      "ephemeral": false
    },
    {
      "name": "rabbitmq",
      "description": "Learn about RabbitMQ",
      "message": "For RabbitMQ please see the documentation at: https://...",
      "ephemeral": false
    },
    {
      "name": "rules",
      "description": "Server rules",
      "message": "**Rules:**\n1. Be respectful\n2. No spam",
      "ephemeral": true
    }
  ],

  "no_ping": {
    "enabled": false,
    "protected_roles": ["ROLE_ID_OWNER", "ROLE_ID_ADMIN", "ROLE_ID_MOD"],
    "message": "{user} You are not allowed to ping **{role}**!",
    "delete_message": true
  },

  "counting_game": {
    "enabled": false,
    "channel_id": "",
    "fail_resets": true,
    "delete_wrong": true,
    "delete_non_numbers": true
  },

  "tickets": {
    "enabled": true,
    "panel_channel": "",
    "log_channel": "",
    "staff_roles": "",
    "discord_category": "",
    "max_open_per_user": 3,
    "categories": [
      {
        "id": "smp",
        "name": "SMP",
        "staff_role": " , , ",
        "emoji": "🛠️",
        "description": "En rapport avec AskaWild SMP",
        "subcategories": [
          {
            "id": "connexion",
            "name": "Connexion",
            "emoji": "🔧",
            "description": "Connexion et Bug"
          },
          {
            "id": "mc",
            "name": "Minecraft",
            "emoji": "👤",
            "description": "Question sur Minecraft"
          }
        ]
      },
      {
        "id": "discord",
        "name": "Discord",
        "staff_role": " , , ",
        "emoji": "💰",
        "description": "Tout ce qu'il ya en relation avec discord",
        "subcategories": []
      },
      {
        "id": "partenaire",
        "name": "Partenaire",
        "staff_role": " , , ",
        "emoji": "💡",
        "description": "Suggestions and feedback",
        "subcategories": []
      }
    ]
  }
}